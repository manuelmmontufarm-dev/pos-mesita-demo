# ============================================================
# POS Mesita Demo — Environment Variables
# Copy to .env and fill in real values
# ============================================================

# ---- Database ----
# Get this from Supabase > Settings > Database > Connection string (URI)
# Supabase session pooler (port 5432) — use this for local dev and seeding
DATABASE_URL=postgresql://postgres.gvellbrujylqhemhgfnx:[PASSWORD]@aws-1-us-east-2.pooler.supabase.com:5432/postgres
# Note: Railway uses port 6543 (transaction pooler) in its Variables

# ---- Server ----
PORT=3000
NODE_ENV=development

# App base URL (used in QR callback links; set to your Railway URL in production)
# Production: https://pos-mesita-demo-production.up.railway.app
APP_BASE_URL=http://localhost:3000

# ---- API Authentication ----
# All API calls require: Authorization: Token <API_KEY>
# Generate a strong random key for production
API_KEY=demo-api-key-change-in-production

# ---- MesitaQR / Paga Ya ----
# Leave MESITAQR_API_KEY empty to use mock QR generation (no real API needed for demo)
MESITAQR_BASE_URL=https://api.pagaya.ec
MESITAQR_API_KEY=
MESITAQR_WEBHOOK_SECRET=change-this-to-a-strong-random-secret
MESITAQR_QR_EXPIRY_MINUTES=15

# ---- Contifico (future live wiring — not required for demo) ----
# Set CONTIFICO_ENABLED=true to forward FAC documents to the real Contifico API
CONTIFICO_ENABLED=false
CONTIFICO_BASE_URL=https://api.contifico.com/sistema/api/v1
CONTIFICO_TOKEN=

# ---- Restaurant Info (used in demo invoice headers) ----
RESTAURANT_RUC=0900000001001
RESTAURANT_RAZON_SOCIAL=Demo Restaurante S.A.
RESTAURANT_DIRECCION=Guayaquil, Ecuador
