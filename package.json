{
  "name": "pos-mesita-demo",
  "version": "1.0.0",
  "description": "Demo POS system for MesitaQR + Contifico integration testing",
  "main": "src/app.js",
  "type": "commonjs",
  "scripts": {
    "start": "node scripts/start-production.js",
    "dev": "nodemon src/app.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "node scripts/seed.js",
    "test": "jest --forceExit",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "pos",
    "restaurant",
    "mesitaqr",
    "contifico",
    "ecuador"
  ],
  "author": "jdonoso1",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "prisma": "^5.7.0",
    "qrcode": "^1.5.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
